# Copy these into Vercel → Project → Settings → Environment Variables.
# For local dev, copy this file to .env.local and fill in the values.

# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Supabase → Project Settings → API → service_role (SECRET — never expose to the browser)
# Not used by the V2 foundation yet; reserved for later phases (credits, server writes).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
